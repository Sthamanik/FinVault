# ─── App ───────────────────────────────────────────────
PORT=5000
NODE_ENV=test

# ─── MongoDB ───────────────────────────────────────────
# Use 'mongo' as host when running inside Docker
# Use 'localhost' when running locally without Docker
MONGO_URI=mongodb://mongo:27017/investment_db

# ─── Redis ─────────────────────────────────────────────
# Use 'redis' as host when running inside Docker
# Use 'localhost' when running locally without Docker
REDIS_URI=redis://localhost:6379

# ─── Rate Limiting ─────────────────────────────────────
# All values are optional; defaults are used if omitted
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5
AUTHENTICATED_RATE_LIMIT_WINDOW_MS=900000
AUTHENTICATED_RATE_LIMIT_MAX=100
PUBLIC_RATE_LIMIT_WINDOW_MS=3600000
PUBLIC_RATE_LIMIT_MAX=30

# ─── JWT ───────────────────────────────────────────────
ACCESS_TOKEN_SECRET=your_access_token_secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRY=7d

# ─── Cloudinary ────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── SMTP (Nodemailer) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ADMIN_EMAIL=admin@example.com
